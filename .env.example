# Токен Hugging Face, тип Read: huggingface.co -> Settings -> Access Tokens.
# Под тем же аккаунтом принять условия на страницах моделей, иначе 401:
#   pyannote/speaker-diarization-community-1
#   pyannote/segmentation-3.0
HF_TOKEN=your_huggingface_token_here

ASR_MODEL_NAME=large-v3-turbo
ASR_COMPUTE_TYPE=float16
ASR_BEAM_SIZE=5
ASR_LANGUAGE=ru
PARALLEL_GPU_STAGES=false

DIARIZATION_MODEL_NAME=pyannote/speaker-diarization-community-1

MIN_SPEAKERS=2
MAX_SPEAKERS=
